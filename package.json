{
  "name": "jekyll-cloudflare-redirects",
  "description": "Jekyll Redirect Builder for Cloudflare Sites",
  "version": "1.0.0",
  "author": "SocksTheWolf",
  "type": "module",
  "private": true,
  "homepage": "https://github.com/SocksTheWolf/jekyll-cloudflare-redirects-action",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/SocksTheWolf/jekyll-cloudflare-redirects-action.git"
  },
  "bugs": {
    "url": "https://github.com/SocksTheWolf/jekyll-cloudflare-redirects-action/issues"
  },
  "keywords": [
    "actions",
    "jekyll",
    "cloudflare",
    "redirects"
  ],
  "exports": {
    ".": "./dist/index.js"
  },
  "engines": {
    "node": ">=24"
  },
  "scripts": {
    "bundle": "npm run package",
    "local-action": "npx @github/local-action . src/main.js .env",
    "package": "npx rimraf ./dist && npx rollup --config rollup.config.js",
    "package:watch": "npm run package -- --watch"
  },
  "license": "MIT",
  "dependencies": {
    "@actions/core": "^3.0.0"
  },
  "devDependencies": {
    "@actions/github": "^9.1.1",
    "@rollup/plugin-commonjs": "^29.0.0",
    "@rollup/plugin-node-resolve": "^16.0.3",
    "rimraf": "^6.1.3",
    "rollup": "^4.57.1",
    "wrangler": "^4.114.0"
  },
  "optionalDependencies": {
    "@rollup/rollup-linux-x64-gnu": "*"
  },
  "overrides": {
    "@actions/github": {
      "undici": "latest"
    },
    "@actions/http-client": {
      "undici": "latest"
    }
  }
}